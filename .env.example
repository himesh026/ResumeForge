# Database
DATABASE_URL="file:./dev.db"

# Auth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-super-secret-key-change-this-in-production"

# App URL
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────
# AI Configuration
# ─────────────────────────────────────────
# Mode: "cloud" (default) or "local" (Ollama)
AI_MODE="cloud"

# Gemini API — get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."
# Model options: gemini-2.0-flash (default, fast) | gemini-1.5-pro (more capable)
GEMINI_MODEL="gemini-2.0-flash"

# Local LLM via Ollama (only used when AI_MODE=local)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# ─────────────────────────────────────────
# Email (optional — code prints to console if not set)
# ─────────────────────────────────────────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM="ATS Resume Tailor <noreply@yourapp.com>"

# File Storage
UPLOAD_DIR="./uploads"
OUTPUT_DIR="./outputs"
